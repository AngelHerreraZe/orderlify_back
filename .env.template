NODE_ENV=development
PORT=3000

# ── Base de datos ──────────────────────────────────────────────────────────────
DB_DATABASE=
DB_DIALECT=postgres
DB_HOST=localhost
DB_PORT=5432
DB_PASSWORD=
DB_USERNAME=

# ── JWT ────────────────────────────────────────────────────────────────────────
# Mínimo 32 caracteres aleatorios. Generar con:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SECRETWORD=

# ── Multi-tenant / Subdominios ─────────────────────────────────────────────────
# Dominio base sobre el que viven los subdominios de las empresas.
# Los subdominios se resuelven como <empresa>.<BASE_DOMAIN>
BASE_DOMAIN=orderlify.net

# Orígenes CORS permitidos. Separados por coma.
# Soporta wildcard para aceptar todos los subdominios automáticamente:
#   https://*.orderlify.net  →  acepta empresa.orderlify.net, etc.
# Para desarrollo local con subdominios ficticios:
#   http://localhost:5173,http://empresa.localhost:5173
ALLOWED_ORIGINS=https://*.orderlify.net,http://localhost:5173

# ── Email ──────────────────────────────────────────────────────────────────────
MAIL_USER=
MAIL_PASSWORD=

# PAYPAL CHANGE: llaves para habilitar PayPal junto con Stripe en el registro.
STRIPE_SECRET_KEY=
STRIPE_PRICE_BASIC_MONTHLY=
STRIPE_PRICE_BASIC_ANNUAL=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_ANNUAL=
STRIPE_PRICE_BUSINESS_MONTHLY=
STRIPE_PRICE_BUSINESS_ANNUAL=
PAYPAL_ENV=sandbox
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_CURRENCY=MXN
PAYPAL_BRAND_NAME=Orderlify
PAYPAL_PLAN_BASIC_MONTHLY=
PAYPAL_PLAN_BASIC_ANNUAL=
PAYPAL_PLAN_PRO_MONTHLY=
PAYPAL_PLAN_PRO_ANNUAL=
PAYPAL_PLAN_BUSINESS_MONTHLY=
PAYPAL_PLAN_BUSINESS_ANNUAL=

# ── Firebase Storage ───────────────────────────────────────────────────────────
FIREBASE_API=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE=
FIREBASE_APP_ID=
